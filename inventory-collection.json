{
	"info": {
		"_postman_id": "inventory-module-collection",
		"name": "Inventory Management Module",
		"description": "API collection for testing the new Scalable Inventory Management Module.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Inventory Operations",
			"item": [
				{
					"name": "Get Inventory (Cached)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/inventory/:productId?variantId=1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								":productId"
							],
							"query": [
								{
									"key": "variantId",
									"value": "1",
									"description": "Optional variant ID"
								}
							],
							"variable": [
								{
									"key": "productId",
									"value": "1"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Initialize Inventory",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": 1,\n    \"variantId\": 1,\n    \"stock\": 100\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/init",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								"init"
							]
						}
					},
					"response": []
				},
				{
					"name": "Reserve Stock",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": 1,\n    \"variantId\": 1,\n    \"quantity\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/reserve",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								"reserve"
							]
						}
					},
					"response": []
				},
				{
					"name": "Confirm Stock",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": 1,\n    \"variantId\": 1,\n    \"quantity\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/confirm",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								"confirm"
							]
						}
					},
					"response": []
				},
				{
					"name": "Release Stock",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": 1,\n    \"variantId\": 1,\n    \"quantity\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/release",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								"release"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Stock (Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"stock\": 150\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"inventory",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api/v1",
			"type": "string"
		},
		{
			"key": "adminToken",
			"value": "your-admin-jwt-token",
			"type": "string"
		}
	]
}
