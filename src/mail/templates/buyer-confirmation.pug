doctype html
html
  head
    meta(charset="UTF-8")
    title #{subject}
    style.
      body { font-family: Arial, sans-serif; background: #f8f9fa; padding: 20px; }
      .container { max-width: 700px; margin: auto; background: #fff; padding: 25px; border-radius: 8px; }
      .title { font-size: 22px; font-weight: bold; margin-bottom: 10px; color: #333; }
      .section-title { font-size: 18px; font-weight: bold; margin: 20px 0 8px; border-bottom: 1px solid #ddd; padding-bottom: 5px; }
      .info-box { margin-bottom: 15px; }
      .info-box p { margin: 3px 0; }
      img.product-img { width: 120px; height: auto; border-radius: 8px; margin-right: 10px; }
      .label-img { width: 100%; max-width: 250px; margin: 10px 0; border: 1px solid #ccc; }

  body
    .container
      .title Your order is confirmed! 🎉

      p Hello #{order.buyer.firstName} #{order.buyer.lastName},  
      p Thank you for your purchase on Pet Attix! Here are your order details:

      // ORDER DETAILS
      .section-title Order Details
      .info-box
        p Order ID: #{order.id}
        p Status: #{order.status.split("_").join(" ")}
        p Payment Status: #{order.paymentStatus.toUppercase()}
        p Total Amount: #{pricingInfo.total} #{pricingInfo.currency}
        p Parcel ID: #{order.parcel_id}

      // SELLER DETAILS
      .section-title Seller Details
      .info-box
        p Name: #{order.seller.firstName} #{order.seller.lastName}
        p Email: #{order.seller.email}

      // PRODUCT DETAILS
      .section-title Product Details
      .info-box
        p Name: #{order.product.product_name}
        p Price: #{order.product.selling_price} #{pricingInfo.currency}
        p Category: #{order.product.category}
        p Condition: #{order.product.condition}
        p Quantity: #{order.product.quantity}
        p Description: #{order.product.description}

        if order.product.images && order.product.images.length
          p Product Images:
          each img in order.product.images
            img.product-img(src=`${process.env.BASE_URL}/${img.image}`)

      // PAYMENT BREAKDOWN
      .section-title Payment Breakdown
      .info-box
        p Currency : #{pricingInfo.currency}
        p Product Price: #{pricingInfo.productPrice} 
        p Protection Fee: #{pricingInfo.productProtectionFee} 
        p Delivery Charge: #{pricingInfo.deliveryCharge} 
        p Delivery Protection: #{pricingInfo.deliveryProtectionFee} 
        p Total: #{pricingInfo.total} 

      // DELIVERY INFO
      if order.deliveryInfo
        .section-title Delivery Address
        .info-box
          p Name: #{order.deliveryInfo.name}
          p Address: #{order.deliveryInfo.address}
          p City: #{order.deliveryInfo.city}
          p Postal Code: #{order.deliveryInfo.postal_code}
          p Country: #{order.deliveryInfo.country}

      // PARCEL DETAILS (Sendcloud)
      if parcelInfo.parcel
        .section-title Shipping & Tracking
        .info-box
          p Tracking Number: #{parcelInfo.parcel.tracking_number}
          p Shipping Method: #{parcelInfo.parcel.shipping_method_checkout_name}
          p Carrier: #{parcelInfo.parcel.carrier.code}

          if parcelInfo.parcel.label && parcelInfo.parcel.label.normal_printer
            p Shipping Labels (A4/Normal Printer):
            each url in parcelInfo.parcel.label.normal_printer
              a(href=url target="_blank") View Label
              br

          if parcelInfo.parcel.label && parcelInfo.parcel.label.label_printer
            p Label Printer Version:
            a(href=parcelInfo.parcel.label.label_printer target="_blank") View Label Printer Format

          if parcelInfo.parcel.documents
            p Documents:
            each doc in parcelInfo.parcel.documents
              a(href=doc.link target="_blank") #{doc.type} (#{doc.size})
              br

      hr
      p Thank you for shopping with Pet Attix!
