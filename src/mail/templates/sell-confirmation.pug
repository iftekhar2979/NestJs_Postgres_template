doctype html
html
  head
    meta(charset="UTF-8")
    title #{subject}
    style.
      body { font-family: Arial, sans-serif; background: #f8f9fa; padding: 20px; }
      .container { max-width: 700px; margin: auto; background: #fff; padding: 25px; border-radius: 8px; }
      .title { font-size: 22px; font-weight: bold; margin-bottom: 10px; color: #333; }
      .section-title { font-size: 18px; font-weight: bold; margin: 20px 0 8px; border-bottom: 1px solid #ddd; padding-bottom: 5px; }
      .info-box { margin-bottom: 15px; }
      .info-box p { margin: 3px 0; }
      img.product-img { width: 120px; height: auto; border-radius: 8px; margin-right: 10px; }
      .label-img { width: 100%; max-width: 250px; margin: 10px 0; border: 1px solid #ccc; }

  body
    .container
      .title Your product has been sold 🎉

      p Hello #{order.seller.firstName} #{order.seller.lastName},  
      p Your product has been purchased on Pet Attix! Below are the details:

      // ORDER DETAILS
      .section-title Order Details
      .info-box
        p Order ID: #{order.id}
          p Status: #{order.status}
        p Payment Status: #{order.paymentStatus}
        p Parcel ID: #{order.parcelId}

      // BUYER DETAILS
      .section-title Buyer Details
      .info-box
        p Name: #{order.buyer.firstName} #{order.buyer.lastName}
        p Email: #{order.buyer.email}
        p Phone: #{order.buyer.phone}

      // PRODUCT DETAILS
      .section-title Product Details
      .info-box
        p Name: #{product.product_name}
        p Price: #{product.selling_price} GBP
        p Category: #{product.category}
        p Condition: #{product.condition}
        p Description: #{product.description}

      if order.product.images && order.product.images.length
        .info-box
          p Product Images:
          each img in productImages
            img.product-img(src=`${process.env.BASE_URL}/${img.image}`)

      // SENDCLOUD PARCEL DETAILS
      if parcelInfo.parcel
        .section-title Shipping & Label Details
        .info-box
          p Tracking Number: #{parcelInfo.parcel.tracking_number}
          p Shipping Method: #{parcelInfo.parcel.shipping_method_checkout_name}
          p Carrier: #{parcel.parcel.carrier.code}

          if parcel.parcel.label && parcel.parcel.label.normal_printer
            p Shipping Labels (A4/Normal Printer):
            each url in parcel.parcel.label.normal_printer
              a(href=url target="_blank") View Label
              br

          if parcel.parcel.label.label_printer
            p Label Printer URL:
            a(href=parcel.parcel.label.label_printer target="_blank") View Label Printer Format

          if parcel.parcel.documents
            p Download Documents:
            each doc in parcel.parcel.documents
              a(href=doc.link target="_blank") #{doc.type} (#{doc.size})
              br

      hr
      p Thank you for selling with Pet Attix!
